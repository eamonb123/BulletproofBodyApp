  "customization_hacks": {
    "starbucks": [
      "Sub nonfat milk → saves 60-80 calories on any milk-based drink",
      "Sub sugar-free vanilla syrup → saves ~80 calories (20 cal per pump, 4 pumps in Grande)",
      "No whipped cream → saves 70-110 calories",
      "Light ice → more drink volume, same calories",
      "Ask for 'skinny' version of any latte (nonfat milk + sugar-free syrup)",
      "Half pumps of syrup → cuts sugar by 50% with minimal taste difference",
      "Sub oat milk instead of whole milk → saves ~40 cal, adds 1g fiber",
      "Cold foam (nonfat) instead of sweet cream → saves ~60 cal",
      "Blonde espresso has slightly more caffeine than regular"
    ],
    "dunkin": [
      "Specify 'black' or 'unsweetened' — Dunkin' default may include cream and sugar",
      "Ask for 1 swirl instead of standard 3 → saves ~100 cal",
      "Flavor shots (unsweetened) vs flavor swirls (sweetened) — shots add ~5 cal, swirls add ~50-80 cal each",
      "Sub skim milk in any latte → saves ~70 cal vs whole milk",
      "Skip the whipped cream on specialty drinks → saves ~60 cal",
      "Small size at Dunkin' is 10oz — often enough caffeine at fraction of calories",
      "Ask for 'light cream' or 'splash of cream' instead of full cream pour"
    ]
  }
