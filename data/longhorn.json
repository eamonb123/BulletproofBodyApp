    {
      "id": "longhorn_parmesan_chicken_lean",
      "name": "Lean Lemon Garlic Chicken & Broccoli",
      "description": "Lemon Garlic Chicken (9 oz), Fresh Steamed Broccoli, Plain Sweet Potato, skip bread — save ~720 cal, keep 62g protein",
      "meal_type": "meal",
      "is_swap": true,
      "swap_for": "longhorn_parmesan_chicken_dinner",
